---
interface Props {
  title: string;
  description: string;
  imagePlaceholder?: string;
  href?: string;
}

const { title, description, imagePlaceholder = "martial-arts-placeholder.jpg", href = "/programs" } = Astro.props;
---
<div class="program-card">
  <div class="card-image">
    <!-- Placeholder SVG for images -->
    <svg width="100%" height="240" viewBox="0 0 400 240" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="cardGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:#1E1E1E;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#333;stop-opacity:1" />
        </linearGradient>
      </defs>
      <rect width="100%" height="100%" fill="url(#cardGrad)" />
      <path d="M0 240 L400 240 L400 180 L0 220 Z" fill="#A50000" fill-opacity="0.3" />
      <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="#ccc" font-family="Oswald" font-size="24" text-transform="uppercase">{title}</text>
    </svg>
  </div>
  <div class="card-content">
    <h3>{title}</h3>
    <p>{description}</p>
    <a href={href} class="btn-text">Explore Program <span>&rarr;</span></a>
  </div>
</div>

<style>
  .program-card {
    background: var(--color-white);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: var(--transition);
    border: 1px solid #eee;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .program-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-red);
  }

  .card-image {
    position: relative;
    overflow: hidden;
  }

  .card-image svg {
    transition: transform 0.5s ease;
  }

  .program-card:hover .card-image svg {
    transform: scale(1.05);
  }

  .card-content {
    padding: 2rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .card-content h3 {
    color: var(--color-black);
    margin-bottom: 1rem;
    font-size: 1.5rem;
    transition: var(--transition);
  }

  .program-card:hover .card-content h3 {
    color: var(--color-red);
  }

  .card-content p {
    font-size: 1rem;
    color: #666;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .btn-text {
    color: var(--color-red);
    text-decoration: none;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.9rem;
    font-family: var(--font-heading);
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: var(--transition);
  }

  .btn-text span {
    transition: transform 0.3s ease;
  }

  .btn-text:hover {
    color: var(--color-red-dark);
  }

  .btn-text:hover span {
    transform: translateX(5px);
  }
</style>
