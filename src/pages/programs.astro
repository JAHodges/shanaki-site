---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Programs">
  <section class="programs-hero section-padding">
    <div class="container text-center">
      <h1>Our Programs</h1>
      <p>Martial Arts for every age and skill level in Wytheville.</p>
    </div>
  </section>

  <section class="programs-detail section-padding">
    <div class="container">
      <div class="program-detail-item">
        <div class="detail-content">
          <h2>Kids Kikkin' It (Pre-K)</h2>
          <p>Our Kids Kikkin' It program is specifically designed for children aged 3 to 5. We focus on early childhood development through martial arts, building coordination, focus, and listening skills in a fun and engaging environment.</p>
          <a href="/programs/pre-k" class="btn">View Pre-K Program</a>
        </div>
        <div class="detail-image">
           <svg width="100%" height="300" viewBox="0 0 500 300" xmlns="http://www.w3.org/2000/svg">
            <rect width="100%" height="100%" fill="#eee" />
            <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="#ccc" font-size="20">Kids Kikkin It Placeholder</text>
          </svg>
        </div>
      </div>

      <div class="program-detail-item reverse">
        <div class="detail-content">
          <h2>After School Program</h2>
          <p>Providing a productive and safe alternative for your child's afternoon. Includes transportation from local schools, supervised study time, and daily martial arts classes to reinforce honor and discipline.</p>
          <a href="/programs/after-school" class="btn">View After School Program</a>
        </div>
        <div class="detail-image">
           <svg width="100%" height="300" viewBox="0 0 500 300" xmlns="http://www.w3.org/2000/svg">
            <rect width="100%" height="100%" fill="#eee" />
            <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="#ccc" font-size="20">After School Placeholder</text>
          </svg>
        </div>
      </div>

      <div class="program-detail-item">
        <div class="detail-content">
          <h2>Youth & Adult Classes</h2>
          <p>Our core classes combine the tradition of Shotokan Karate with the unique Shanaki Blended Martial Arts system. Developed by Grand Master Penny Shannon, this approach combines techniques from Shotokan, Judo, Jujitsu, Aikido, and Kung Fu for a versatile and effective self-defense education.</p>
          <p><strong>Youth:</strong> 6:00 PM - 7:00 PM (Tue/Thu)<br><strong>Adult:</strong> 7:00 PM - 8:30 PM (Tue/Thu)</p>
          <a href="/contact" class="btn">Join a Class</a>
        </div>
        <div class="detail-image">
           <svg width="100%" height="300" viewBox="0 0 500 300" xmlns="http://www.w3.org/2000/svg">
            <rect width="100%" height="100%" fill="#eee" />
            <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="#ccc" font-size="20">Classes Placeholder</text>
          </svg>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .programs-hero {
    background-color: var(--color-black);
    color: var(--color-white);
    border-bottom: 5px solid var(--color-red);
  }

  .program-detail-item {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    margin-bottom: 8rem;
  }

  .program-detail-item.reverse {
    direction: rtl;
  }

  .program-detail-item.reverse .detail-content {
    direction: ltr;
  }

  .detail-content h2 {
    color: var(--color-red);
    margin-bottom: 1.5rem;
    font-size: 2.2rem;
  }

  .detail-content p {
    margin-bottom: 1.5rem;
    font-size: 1.1rem;
    color: #444;
  }

  @media (max-width: 768px) {
    .program-detail-item {
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 4rem;
    }
    .program-detail-item.reverse {
      direction: ltr;
    }
  }
</style>
