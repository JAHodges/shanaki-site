---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Grand Master Penny Shannon">
  <section class="profile-hero section-padding bg-dark">
    <div class="container">
      <div class="profile-grid">
        <div class="profile-visual animate">
          <div class="action-silhouette">
            <!-- Meditation/Wisdom Silhouette -->
            <svg viewBox="0 0 400 500" xmlns="http://www.w3.org/2000/svg">
              <rect width="100%" height="100%" fill="#1a1a1a" />
              <path d="M200 100 L230 200 L300 200 L240 260 L260 350 L200 300 L140 350 L160 260 L100 200 L170 200 Z" fill="#A50000" opacity="0.5" />
              <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="#fff" font-family="Oswald" font-size="20">FOUNDER SILHOUETTE</text>
            </svg>
          </div>
        </div>
        <div class="profile-info animate">
          <div class="badge">Founder & President</div>
          <h1>Grand Master <span>Penny Shannon</span></h1>
          <p class="rank">10th Degree Black Belt</p>
          <div class="credentials-row">
            <span>40+ Years Experience</span>
            <span class="dot"></span>
            <span>Hall of Fame Inductee</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bio-content section-padding">
    <div class="container">
      <div class="text-layout">
        <div class="bio-verbatim">
          <p>Grand Master Penny Shannon is the founder and President of Shanaki Martial Arts, Inc. She began her martial arts training in 1974 under the instruction of Master Robert A. Trias, the father of Karate in America. She was the first woman in the state of Illinois to be promoted to the rank of Black Belt in the United States Karate Association.</p>

          <p>Grand Master Shannon has over 40 years of experience in the martial arts. she has trained in several styles including Shotokan, Goju-Ryu, Shorei-Ryu, and Tae Kwon Do. She has also trained in several weapons including the Bo, Sai, Tonfa, Nunchaku, and Kama.</p>

          <p>Grand Master Shannon has competed in many tournaments throughout her career and has won numerous awards and trophies. She has also been inducted into several Martial Arts Halls of Fame.</p>

          <p>Grand Master Shannon's mission is to provide quality martial arts instruction to students of all ages and to help them develop self-discipline, self-confidence, and respect for themselves and others. She believes that martial arts is not just about fighting, but about personal growth and development.</p>
        </div>
        <div class="sidebar">
          <div class="quick-facts">
            <h4>Quick Facts</h4>
            <ul>
              <li>Started Training: 1974</li>
              <li>Base Style: Shotokan</li>
              <li>Rank: 10th Dan</li>
            </ul>
          </div>
          <a href="/instructors" class="btn btn-outline-dark">Back to Instructors</a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .profile-hero {
    border-bottom: 5px solid var(--color-red);
    padding-bottom: 0;
  }

  .profile-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: end;
  }

  .action-silhouette {
    border-radius: 8px 8px 0 0;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    background: #1a1a1a;
  }

  .profile-info {
    padding-bottom: 4rem;
  }

  .profile-info h1 {
    font-size: 4rem;
    margin: 1rem 0;
    line-height: 1;
  }

  .profile-info h1 span { color: var(--color-red); }

  .profile-info .rank {
    font-size: 1.5rem;
    color: #888;
    margin-bottom: 2rem;
  }

  .credentials-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 1px;
    font-family: var(--font-heading);
    color: var(--color-red);
  }

  .dot { width: 6px; height: 6px; background: #444; border-radius: 50%; }

  .text-layout {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 5rem;
  }

  .bio-verbatim p {
    font-size: 1.2rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    color: #333;
  }

  .sidebar {
    position: sticky;
    top: 120px;
    height: fit-content;
  }

  .quick-facts {
    background: #f9f9f9;
    padding: 2rem;
    border-radius: 4px;
    margin-bottom: 2rem;
    border-left: 4px solid var(--color-red);
  }

  .quick-facts h4 {
    margin-bottom: 1.5rem;
    color: var(--color-black);
  }

  .quick-facts ul {
    list-style: none;
  }

  .quick-facts li {
    margin-bottom: 0.8rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid #eee;
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
  }

  .btn-outline-dark {
    border-color: var(--color-black);
    color: var(--color-black);
    width: 100%;
    text-align: center;
  }

  .btn-outline-dark:hover {
    background: var(--color-black);
    color: var(--color-white);
  }

  @media (max-width: 992px) {
    .profile-grid, .text-layout { grid-template-columns: 1fr; gap: 3rem; }
    .profile-info { padding-bottom: 2rem; }
    .profile-info h1 { font-size: 3rem; }
  }
</style>
