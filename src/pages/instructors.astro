---
import MainLayout from '../layouts/MainLayout.astro';

const instructors = [
  { 
    name: "Grand Master Penny Shannon", 
    rank: "10th Degree Black Belt", 
    title: "Founder & President",
    slug: "penny-shannon",
    summary: "First woman in Illinois promoted to Black Belt in the USKA. 40+ years experience."
  },
  { 
    name: "Master Scot Shannon", 
    rank: "6th Degree Black Belt", 
    title: "Master Instructor",
    slug: "scot-shannon",
    summary: "State and National champion. Expert in traditional weapons and self-defense."
  },
  { 
    name: "Master Tammy Shannon Warden", 
    rank: "5th Degree Black Belt", 
    title: "Master Instructor",
    slug: "tammy-shannon-warden",
    summary: "Certified fitness instructor specializing in youth development and character building."
  },
  { 
    name: "Master Jason Gullion", 
    rank: "5th Degree Black Belt", 
    title: "Master Instructor",
    slug: "jason-gullion",
    summary: "Dedicated instructor for 15+ years. Specialist in Aikido and Brazilian Jiu-Jitsu."
  },
  { 
    name: "Master Shawna Shannon", 
    rank: "4th Degree Black Belt", 
    title: "Master Instructor",
    slug: "shawna-shannon",
    summary: "Licensed massage therapist utilizing body mechanics to improve martial arts technique."
  },
  { 
    name: "Master L. Leigh Shannon Arrendondo", 
    rank: "4th Degree Black Belt", 
    title: "Master Instructor",
    slug: "leigh-shannon-arrendondo",
    summary: "Certified yoga instructor focused on self-awareness and personal growth through kata."
  },
  { 
    name: "Sensei Trey Warden", 
    rank: "2nd Degree Black Belt", 
    title: "Instructor",
    slug: "trey-warden",
    summary: "Multi-sport athlete and role model dedicated to student goals and discipline."
  }
];
---

<MainLayout title="Instructors">
  <section class="instructors-hero section-padding bg-dark text-center">
    <div class="container animate">
      <div class="badge">Certified Leadership</div>
      <h1>Our <span>Instructors</span></h1>
      <p class="hero-subtitle">Meet the team dedicated to preserving the legacy of Shanaki.</p>
      <div class="trust-bar">
        <span>Minimum 2nd Degree Black Belt</span>
        <span class="dot"></span>
        <span>Certified Educators</span>
        <span class="dot"></span>
        <span>Legacy of Excellence</span>
      </div>
    </div>
  </section>

  <section class="gallery-section section-padding">
    <div class="container">
      <div class="section-header animate">
        <h2>The Teaching Team</h2>
        <p>Click on any instructor to read their full, first-person story and martial arts philosophy.</p>
      </div>

      <div class="instructors-grid animate">
        {instructors.map(inst => (
          <a href={`/instructors/${inst.slug}`} class="instructor-card">
            <div class="inst-visual">
              <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <circle cx="50" cy="50" r="48" fill="#f9f9f9" stroke="#eee" stroke-width="1" />
                <path d="M50 30 L60 50 L40 50 Z" fill="#A50000" opacity="0.5" />
              </svg>
            </div>
            <div class="inst-content">
              <p class="inst-title">{inst.title}</p>
              <h3>{inst.name}</h3>
              <p class="inst-rank">{inst.rank}</p>
              <p class="inst-summary">{inst.summary}</p>
              <span class="read-more">Read Full Story &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="standard-section section-padding bg-light">
    <div class="container text-center animate">
      <div class="cert-box">
        <h2>The Shanaki Standard</h2>
        <p>Every lead instructor has passed a specific certification course developed by Grand Master Penny Shannon. This ensures safety, consistency, and adherence to the core values of our system.</p>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  h1 span { color: var(--color-red); }
  
  .hero-subtitle {
    font-size: 1.5rem;
    max-width: 800px;
    margin: 1.5rem auto;
    font-family: var(--font-heading);
    letter-spacing: 1px;
  }

  .trust-bar {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2rem;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    color: var(--color-red);
  }

  .dot { width: 6px; height: 6px; background-color: #333; border-radius: 50%; }

  .instructors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 3rem;
  }

  .instructor-card {
    background: var(--color-white);
    border-radius: 4px;
    padding: 3rem 2rem;
    text-align: center;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
    border-top: 4px solid var(--color-gray);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .instructor-card:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-red);
  }

  .inst-visual {
    width: 80px;
    height: 80px;
    margin-bottom: 2rem;
  }

  .inst-title {
    text-transform: uppercase;
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-red);
    font-size: 0.8rem;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
  }

  .instructor-card h3 {
    font-size: 1.6rem;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .inst-rank {
    font-weight: 600;
    color: #888;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }

  .inst-summary {
    font-size: 0.95rem;
    color: #666;
    line-height: 1.6;
    margin-bottom: 2rem;
    flex-grow: 1;
  }

  .read-more {
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.85rem;
    color: var(--color-black);
    transition: color 0.3s ease;
  }

  .instructor-card:hover .read-more {
    color: var(--color-red);
  }

  .cert-box {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem;
    background: white;
    border: 1px solid #eee;
    box-shadow: var(--shadow-md);
  }

  .cert-box h2 { margin-bottom: 1.5rem; color: var(--color-red); }

  @media (max-width: 768px) {
    .trust-bar { flex-direction: column; gap: 0.5rem; }
    .dot { display: none; }
  }
</style>
