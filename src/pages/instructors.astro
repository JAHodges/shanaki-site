---
import MainLayout from '../layouts/MainLayout.astro';

const grandMaster = { 
  name: "Grand Master Penny Shannon", 
  rank: "10th Degree Black Belt", 
  title: "Founder & President",
  slug: "penny-shannon",
  summary: "The visionary founder of the Shanaki system with over 40 years of experience. A pioneer for women in the martial arts and inductee into multiple Halls of Fame."
};

const masters = [
  { 
    name: "Master Scot Shannon", 
    rank: "7th Degree Black Belt", 
    title: "Master Instructor",
    slug: "scot-shannon",
    summary: "Professional martial artist and film choreographer. Holds titles as a state and regional Olympic qualifier and was rated #1 in seven states by the PKA."
  },
  { 
    name: "Master Tammy Shannon Warden", 
    rank: "6th Degree Black Belt", 
    title: "Master Instructor",
    slug: "tammy-shannon-warden",
    summary: "Formerly the NASKA #1 rated female black belt competitor in the nation. A professional Nurse Practitioner and pioneer in martial arts fitness videos."
  },
  { 
    name: "Master Jason Gullion", 
    rank: "6th Degree Black Belt", 
    title: "Master Instructor",
    slug: "jason-gullion",
    summary: "Vice President of Shanaki Martial Arts and an expert in multiple disciplines including Modern Arnis and Jiu-Jitsu. A dedicated nurse and educator."
  },
  { 
    name: "Master Shawna Shannon", 
    rank: "6th Degree Black Belt", 
    title: "Master Instructor",
    slug: "shawna-shannon",
    summary: "Manager of the 'Kids Kikkin It' program with a degree in Early Childhood Development. An accomplished competitor and hall of fame instructor."
  },
  { 
    name: "Master L. Leigh Shannon Arrendondo", 
    rank: "4th Degree Black Belt", 
    title: "Master Instructor",
    slug: "leigh-shannon-arrendondo",
    summary: "Director of the Atlanta division and champion competitor. Dedicated to empowering women and children through self-defense and self-esteem."
  },
  { 
    name: "Sensei Trey Warden", 
    rank: "3rd Degree Black Belt", 
    title: "Instructor",
    slug: "trey-warden",
    summary: "A certified instructor since age 14 who began training at age 2. An honor student, multi-sport athlete, and active member of the junior ROTC."
  }
];
---

<MainLayout title="Instructors">
  <section class="instructors-hero section-padding bg-dark text-center">
    <div class="container animate">
      <div class="badge">Certified Leadership</div>
      <h1>Our <span>Instructors</span></h1>
      <p class="hero-subtitle">Meet the team dedicated to preserving the legacy of Shanaki Martial Arts.</p>
      <div class="trust-bar">
        <span>Master Level Instruction</span>
        <span class="dot"></span>
        <span>Certified Educators</span>
        <span class="dot"></span>
        <span>Legacy of Excellence</span>
      </div>
    </div>
  </section>

  <!-- Founder Spotlight -->
  <section class="founder-spotlight section-padding">
    <div class="container">
      <div class="founder-card animate">
        <div class="founder-grid">
          <div class="founder-visual">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
              <rect width="100%" height="100%" fill="#1a1a1a" />
              <path d="M50 25 L75 75 L25 75 Z" fill="#A50000" opacity="0.4" />
              <text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" fill="#fff" font-family="Oswald" font-size="8" text-transform="uppercase">Founder</text>
            </svg>
          </div>
          <div class="founder-content">
            <div class="inst-tag">Studio Founder</div>
            <h2>{grandMaster.name}</h2>
            <p class="inst-rank-top">{grandMaster.rank}</p>
            <p class="inst-summary-top">{grandMaster.summary}</p>
            <a href={`/instructors/${grandMaster.slug}`} class="btn btn-small">Read Full Story &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Grid -->
  <section class="team-section section-padding bg-light">
    <div class="container">
      <div class="section-header animate">
        <h2>The Master Black Belts</h2>
        <p>A legacy of discipline, expertise, and dedication.</p>
      </div>

      <div class="instructors-grid animate">
        {masters.map(inst => (
          <a href={`/instructors/${inst.slug}`} class="instructor-card">
            <div class="inst-content">
              <p class="inst-title">{inst.title}</p>
              <h3>{inst.name}</h3>
              <p class="inst-rank">{inst.rank}</p>
              <p class="inst-summary">{inst.summary}</p>
              <span class="read-more">View Profile &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="standard-section section-padding">
    <div class="container animate">
      <div class="cert-box">
        <h2 class="text-center">The Shanaki Standard</h2>
        <p>Every lead instructor has passed a specific certification course developed by Grand Master Penny Shannon. This ensures safety, consistency, and adherence to the core values of our system. While we offer instruction in several styles, Shotokan remains the base style for all student ranking.</p>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  h1 span { color: var(--color-red); }
  
  .hero-subtitle {
    font-size: 1.25rem;
    max-width: 700px;
    margin: 1.5rem auto;
    font-family: var(--font-heading);
    letter-spacing: 1px;
    opacity: 0.9;
  }

  .trust-bar {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2rem;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.8rem;
    color: var(--color-red);
  }

  .dot { width: 4px; height: 4px; background-color: #444; border-radius: 50%; }

  /* Founder Spotlight */
  .founder-card {
    background: var(--color-white);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid #eee;
    max-width: 1000px;
    margin: 0 auto;
  }

  .founder-grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    align-items: stretch;
  }

  .founder-visual {
    background: var(--color-black);
    height: 100%;
  }

  .founder-visual svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .founder-content {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .inst-tag {
    color: var(--color-red);
    text-transform: uppercase;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 2px;
    margin-bottom: 0.5rem;
  }

  .founder-content h2 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-black);
  }

  .inst-rank-top {
    font-weight: 600;
    color: #888;
    text-transform: uppercase;
    font-size: 1rem;
    margin-bottom: 1.5rem;
    letter-spacing: 1px;
  }

  .inst-summary-top {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    color: #555;
  }

  .btn-small {
    padding: 0.8rem 1.5rem;
    font-size: 0.9rem;
    align-self: flex-start;
  }

  /* Team Grid */
  .instructors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
  }

  .instructor-card {
    background: var(--color-white);
    border-radius: 4px;
    padding: 2.5rem;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
    border-top: 3px solid #ddd;
    display: flex;
    flex-direction: column;
  }

  .instructor-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-top-color: var(--color-red);
  }

  .inst-title {
    text-transform: uppercase;
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-red);
    font-size: 0.8rem;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
  }

  .instructor-card h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-black);
  }

  .instructor-card .inst-rank {
    color: #888;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .instructor-card .inst-summary {
    color: #666;
    font-size: 0.95rem;
    line-height: 1.6;
    flex-grow: 1;
  }

  .read-more {
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.85rem;
    color: var(--color-red);
    letter-spacing: 1px;
    margin-top: 2rem;
  }

  /* Cert Box */
  .cert-box {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem;
    background: #fdfdfd;
    border: 1px solid #eee;
    box-shadow: var(--shadow-md);
    text-align: center;
    border-left: 4px solid var(--color-red);
  }

  .cert-box h2 { margin-bottom: 1rem; color: var(--color-red); font-size: 1.8rem; }
  .cert-box p { font-size: 1rem; line-height: 1.7; color: #555; }

  @media (max-width: 992px) {
    .founder-grid { grid-template-columns: 1fr; }
    .founder-visual { height: 200px; }
    .founder-content { padding: 2.5rem; }
  }

  @media (max-width: 768px) {
    .trust-bar { flex-direction: column; gap: 0.5rem; }
    .dot { display: none; }
    .instructor-card { padding: 2rem; }
    .founder-content h2 { font-size: 2rem; }
  }
</style>
