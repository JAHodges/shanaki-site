---
import MainLayout from '../layouts/MainLayout.astro';

const grandMaster = { 
  name: "Grand Master Penny Shannon", 
  rank: "10th Degree Black Belt", 
  title: "Founder & President",
  slug: "penny-shannon",
  summary: "First woman in the state of Illinois to be promoted to the rank of Black Belt in the United States Karate Association. With over 40 years of experience, she is the visionary behind the Shanaki system."
};

const masters = [
  { 
    name: "Master Scot Shannon", 
    rank: "6th Degree Black Belt", 
    title: "Master Instructor",
    slug: "scot-shannon",
    summary: "State and National champion. Expert in traditional weapons and self-defense with over 30 years of training."
  },
  { 
    name: "Master Tammy Shannon Warden", 
    rank: "5th Degree Black Belt", 
    title: "Master Instructor",
    slug: "tammy-shannon-warden",
    summary: "Certified fitness instructor specializing in youth development and building confidence in children."
  },
  { 
    name: "Master Jason Gullion", 
    rank: "5th Degree Black Belt", 
    title: "Master Instructor",
    slug: "jason-gullion",
    summary: "Dedicated instructor for 15+ years. Specialist in Aikido, Brazilian Jiu-Jitsu, and traditional weapons."
  },
  { 
    name: "Master Shawna Shannon", 
    rank: "4th Degree Black Belt", 
    title: "Master Instructor",
    slug: "shawna-shannon",
    summary: "Licensed massage therapist utilizing deep knowledge of body mechanics to improve martial arts technique."
  },
  { 
    name: "Master L. Leigh Shannon Arrendondo", 
    rank: "4th Degree Black Belt", 
    title: "Master Instructor",
    slug: "leigh-shannon-arrendondo",
    summary: "Certified yoga instructor focused on self-awareness, personal growth, and fluid motion."
  },
  { 
    name: "Sensei Trey Warden", 
    rank: "2nd Degree Black Belt", 
    title: "Instructor",
    slug: "trey-warden",
    summary: "Multi-sport athlete and certified educator dedicated to being a positive role model for the next generation."
  }
];
---

<MainLayout title="Instructors">
  <section class="instructors-hero section-padding bg-dark text-center">
    <div class="container animate">
      <div class="badge">Certified Leadership</div>
      <h1>Our <span>Instructors</span></h1>
      <p class="hero-subtitle">Meet the team dedicated to preserving the legacy of Shanaki Martial Arts.</p>
      <div class="trust-bar">
        <span>Minimum 2nd Degree Black Belt</span>
        <span class="dot"></span>
        <span>Certified Educators</span>
        <span class="dot"></span>
        <span>Legacy of Excellence</span>
      </div>
    </div>
  </section>

  <!-- Founder Spotlight -->
  <section class="founder-spotlight section-padding">
    <div class="container">
      <div class="founder-card animate">
        <div class="founder-grid">
          <div class="founder-visual">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
              <rect width="100%" height="100%" fill="#1a1a1a" />
              <path d="M50 20 L80 80 L20 80 Z" fill="#A50000" opacity="0.3" />
              <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="#fff" font-family="Oswald" font-size="10">GM SILHOUETTE</text>
            </svg>
          </div>
          <div class="founder-content">
            <p class="inst-title">{grandMaster.title}</p>
            <h2>{grandMaster.name}</h2>
            <p class="inst-rank">{grandMaster.rank}</p>
            <p class="inst-summary">{grandMaster.summary}</p>
            <a href={`/instructors/${grandMaster.slug}`} class="btn">Read Her Full Story</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Grid -->
  <section class="team-section section-padding bg-light">
    <div class="container">
      <div class="section-header animate">
        <h2>The Master Black Belts</h2>
        <p>A legacy of discipline, expertise, and dedication.</p>
      </div>

      <div class="instructors-grid animate">
        {masters.map(inst => (
          <a href={`/instructors/${inst.slug}`} class="instructor-card">
            <div class="inst-content">
              <p class="inst-title">{inst.title}</p>
              <h3>{inst.name}</h3>
              <p class="inst-rank">{inst.rank}</p>
              <p class="inst-summary">{inst.summary}</p>
              <span class="read-more">Read Full Story &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="standard-section section-padding">
    <div class="container animate">
      <div class="cert-box">
        <h2 class="text-center">The Shanaki Standard</h2>
        <p>Every lead instructor has passed a specific certification course developed by Grand Master Penny Shannon. This ensures safety, consistency, and adherence to the core values of our system. While we offer instruction in several styles, Shotokan remains the base style for all student ranking.</p>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  h1 span { color: var(--color-red); }
  
  .hero-subtitle {
    font-size: 1.5rem;
    max-width: 800px;
    margin: 1.5rem auto;
    font-family: var(--font-heading);
    letter-spacing: 1px;
  }

  .trust-bar {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2rem;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    color: var(--color-red);
  }

  .dot { width: 6px; height: 6px; background-color: #333; border-radius: 50%; }

  /* Founder Spotlight */
  .founder-card {
    background: var(--color-black);
    color: var(--color-white);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border-bottom: 5px solid var(--color-red);
  }

  .founder-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    align-items: center;
  }

  .founder-visual {
    height: 100%;
    min-height: 400px;
  }

  .founder-visual svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .founder-content {
    padding: 4rem;
  }

  .founder-content h2 {
    font-size: 3rem;
    margin-bottom: 0.5rem;
    line-height: 1.1;
  }

  /* Shared Instructor Styles */
  .inst-title {
    text-transform: uppercase;
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-red);
    font-size: 0.85rem;
    letter-spacing: 2px;
    margin-bottom: 1rem;
  }

  .inst-rank {
    font-weight: 600;
    color: #888;
    font-size: 1rem;
    margin-bottom: 2rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .inst-summary {
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    color: #ccc;
  }

  /* Team Grid */
  .instructors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  .instructor-card {
    background: var(--color-white);
    border-radius: 4px;
    padding: 3.5rem 3rem;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
    border-top: 4px solid var(--color-gray);
    display: flex;
    flex-direction: column;
  }

  .instructor-card:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-red);
  }

  .instructor-card h3 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
    color: var(--color-black);
  }

  .instructor-card .inst-rank {
    color: #666;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .instructor-card .inst-summary {
    color: #555;
    font-size: 1rem;
    flex-grow: 1;
  }

  .read-more {
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.9rem;
    color: var(--color-red);
    letter-spacing: 1px;
    margin-top: 2rem;
  }

  /* Cert Box */
  .cert-box {
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem;
    background: #fdfdfd;
    border: 1px solid #eee;
    box-shadow: var(--shadow-md);
    text-align: center;
    border-left: 5px solid var(--color-red);
  }

  .cert-box h2 { margin-bottom: 1.5rem; color: var(--color-red); }
  .cert-box p { font-size: 1.1rem; line-height: 1.8; color: #444; }

  @media (max-width: 992px) {
    .founder-grid { grid-template-columns: 1fr; }
    .founder-visual { min-height: 300px; }
    .founder-content { padding: 3rem 2rem; }
    .founder-content h2 { font-size: 2.2rem; }
  }

  @media (max-width: 768px) {
    .trust-bar { flex-direction: column; gap: 0.5rem; }
    .dot { display: none; }
    .instructor-card { padding: 2.5rem 2rem; }
  }
</style>
