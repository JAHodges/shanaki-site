---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Members Portal">
  <section class="members-hero section-padding">
    <div class="container text-center">
      <h1>Student Resources</h1>
      <p>Access curricula, videos, and studio announcements.</p>
    </div>
  </section>

  <section class="gate-section section-padding">
    <div class="container">
      <div id="password-gate" class="gate-container">
        <h2 class="text-center">Member Login</h2>
        <p class="text-center">Please enter the studio password to access this area.</p>
        <div class="gate-form">
          <input type="password" id="studio-password" placeholder="Enter Password" />
          <button id="gate-submit" class="btn btn-block">Access Portal</button>
        </div>
        <p id="gate-error" class="error-msg"></p>
      </div>

      <div id="member-content" class="content-container hidden">
        <h2 class="text-center">Welcome, Shanaki Students</h2>
        <div class="resource-grid">
          <div class="resource-card">
            <h3>Shotokan Curriculum</h3>
            <p>Download the latest belt requirements and kata guides.</p>
            <a href="#" class="btn btn-outline">Download PDF</a>
          </div>
          <div class="resource-card">
            <h3>Technique Videos</h3>
            <p>Review standard techniques and training drills at home.</p>
            <a href="#" class="btn btn-outline">Watch Videos</a>
          </div>
          <div class="resource-card">
            <h3>Studio News</h3>
            <p>Stay updated on upcoming belt tests and special events.</p>
            <a href="#" class="btn btn-outline">View News</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    // Note: This is a basic static gate, not high security.
    // The "password" here is just for proof of concept.
    const PASSWORD = 'shanaki-warrior'; 
    
    const gateDiv = document.getElementById('password-gate');
    const contentDiv = document.getElementById('member-content');
    const passwordInput = document.getElementById('studio-password');
    const submitBtn = document.getElementById('gate-submit');
    const errorMsg = document.getElementById('gate-error');

    submitBtn.addEventListener('click', () => {
      if (passwordInput.value === PASSWORD) {
        gateDiv.classList.add('hidden');
        contentDiv.classList.remove('hidden');
        sessionStorage.setItem('shanaki_auth', 'true');
      } else {
        errorMsg.textContent = 'Incorrect password. Please try again.';
      }
    });

    // Check if already authenticated in this session
    if (sessionStorage.getItem('shanaki_auth') === 'true') {
      gateDiv.classList.add('hidden');
      contentDiv.classList.remove('hidden');
    }
  </script>
</MainLayout>

<style>
  .members-hero {
    background-color: var(--color-black);
    color: var(--color-white);
    border-bottom: 5px solid var(--color-red);
  }

  .gate-container {
    max-width: 400px;
    margin: 0 auto;
    background: #f9f9f9;
    padding: 3rem;
    border-radius: 8px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }

  .gate-form {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .gate-form input {
    padding: 0.8rem;
    border: 1px solid #ddd;
    border-radius: 4px;
    text-align: center;
  }

  .error-msg {
    color: var(--color-red);
    text-align: center;
    margin-top: 1rem;
    font-size: 0.9rem;
    height: 1.2rem;
  }

  .hidden {
    display: none !important;
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .resource-card {
    background: var(--color-white);
    padding: 2.5rem;
    border-radius: 8px;
    border: 1px solid #eee;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }

  .resource-card h3 {
    color: var(--color-red);
    margin-bottom: 1rem;
  }

  .btn-outline {
    background: transparent;
    border: 2px solid var(--color-red);
    color: var(--color-red);
    margin-top: 1.5rem;
  }

  .btn-outline:hover {
    background: var(--color-red);
    color: var(--color-white);
  }
</style>
